# AI 提供商配置（客户端 + 服务端均可用）
NEXT_PUBLIC_AI_PROVIDER=aliyun
NEXT_PUBLIC_AI_API_KEY=sk-xxx
NEXT_PUBLIC_AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
NEXT_PUBLIC_AI_MODEL=qwen-plus

# OAuth 令牌（用于真实邮件 API 调用）
GMAIL_ACCESS_TOKEN=ya29.xxx
OUTLOOK_ACCESS_TOKEN=xxx

# IMAP 连接参数（可选）
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=user@example.com
IMAP_PASSWORD=xxx

# 备用服务端 AI 密钥（API 路由优先使用）
AI_API_KEY=sk-xxx
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MODEL=qwen-plus
