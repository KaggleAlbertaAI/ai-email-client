# AI 提供商（这里我们指定为阿里云百炼）
NEXT_PUBLIC_AI_PROVIDER=aliyun

# 你的阿里云百炼 API Key (去 https://bailian.console.aliyun.com/ 获取)
NEXT_PUBLIC_AI_API_KEY=sk-808005733599417bbafa56e8c45f57c9

# 阿里云百炼的 OpenAI 兼容接口地址
